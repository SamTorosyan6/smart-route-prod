<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-car-photo" author="sam">
        <createTable tableName="car_photo">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="car_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="photo_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="is_main" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="fk-car-photo-car" author="sam">
        <addForeignKeyConstraint
                baseTableName="car_photo"
                baseColumnNames="car_id"
                constraintName="car_photo_car_id_fk"
                referencedTableName="car"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>