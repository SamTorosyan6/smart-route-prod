<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


    <changeSet id="create-feedback" author="sam">
        <createTable tableName="feedback">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="booking_id" type="INT">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="rating" type="TINYINT">
                <constraints nullable="false"/>
            </column>

            <column name="comment" type="TEXT"/>

            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>

            <column name="reviewer_id" type="INT"/>
            <column name="reviewed_user_id" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="fk-feedback-booking" author="sam">
        <addForeignKeyConstraint
                baseTableName="feedback"
                baseColumnNames="booking_id"
                constraintName="review_booking_id_fk"
                referencedTableName="booking"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="fk-feedback-reviewer" author="sam">
        <addForeignKeyConstraint
                baseTableName="feedback"
                baseColumnNames="reviewer_id"
                constraintName="review_user_id_fk"
                referencedTableName="user"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="fk-feedback-reviewed-user" author="sam">
        <addForeignKeyConstraint
                baseTableName="feedback"
                baseColumnNames="reviewed_user_id"
                constraintName="review_user_id_fk_2"
                referencedTableName="user"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="chk-feedback-rating" author="sam">
        <sql>
            ALTER TABLE feedback
                ADD CONSTRAINT chk_rating CHECK (rating BETWEEN 1 AND 5);
        </sql>
    </changeSet>

</databaseChangeLog>