<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-booking" author="sam">
        <createTable tableName="booking">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="trip_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="passenger_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="seats_requested" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="total_price" type="DECIMAL(8,2)">
                <constraints nullable="false"/>
            </column>

            <column name="status"
                    type="ENUM('PENDING','ACCEPTED','REJECTED','COMPLETED')"
                    defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>

            <column name="canceled_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="fk-booking-trip" author="sam">
        <addForeignKeyConstraint
                baseTableName="booking"
                baseColumnNames="trip_id"
                constraintName="booking_trip_id_fk"
                referencedTableName="trip"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="fk-booking-user" author="sam">
        <addForeignKeyConstraint
                baseTableName="booking"
                baseColumnNames="passenger_id"
                constraintName="booking_user_id_fk"
                referencedTableName="user"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>