<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


    <changeSet id="create-trip" author="sam">
        <createTable tableName="trip">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="driver_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="from_city" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="to_city" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="departure_time" type="DATETIME">
                <constraints nullable="false"/>
            </column>

            <column name="total_seats" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="available_seats" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="price_per_seat" type="DECIMAL(8,2)">
                <constraints nullable="false"/>
            </column>

            <column name="status"
                    type="ENUM('UPCOMING','COMPLETED','CANCELED')"
                    defaultValue="UPCOMING">
                <constraints nullable="false"/>
            </column>

            <column name="smoking_allowed" type="TINYINT(1)" defaultValueNumeric="0"/>
            <column name="pets_allowed" type="TINYINT(1)" defaultValueNumeric="0"/>
            <column name="baggage_allowed" type="TINYINT(1)" defaultValueNumeric="0"/>
            <column name="eat_allowed" type="TINYINT(1)" defaultValueNumeric="0"/>

            <column name="rules" type="TEXT"/>

            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

    <changeSet id="fk-trip-user" author="sam">
        <addForeignKeyConstraint
                baseTableName="trip"
                baseColumnNames="driver_id"
                constraintName="trip_user_id_fk"
                referencedTableName="user"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>